<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scene with CSS</title>
  <style>
    body {
      margin: 0;
      background-color: white;
      display: flex;
      height: 100vh;
      align-items: center;
      justify-content: space-around;
    }

    .scene {
      position: relative;
      width: 400px;
      height: 400px;
    }

    .lady {
      position: absolute;
      width: 200px;
      height: 300px;
      background-color: blue;
      top: 50px;
      left: 50px;
    }

    .man {
      position: absolute;
      width: 200px;
      height: 300px;
      background-color: brown;
      top: 50px;
      right: 50px;
    }

    .fire {
      position: absolute;
      width: 50px;
      height: 100px;
      background-color: orange;
      bottom: 50px;
      right: 100px;
    }
  </style>
</head>
<body>
  <div class="scene">
    <div class="lady"></div>
    <div class="man"></div>
    <div class="fire"></div>
  </div>
</body>
</html>
